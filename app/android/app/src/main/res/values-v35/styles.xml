<?xml version="1.0" encoding="utf-8"?>
<!-- Android 15 (API 35) force-enables edge-to-edge for apps targeting 35,
     which would draw the WebView under the status bar and break the map
     layout. Opt out to keep the pre-35 window behavior; revisit when the
     web app handles safe-area insets on Android (the attribute is
     deprecated and will eventually be removed). -->
<resources>
    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <item name="android:windowOptOutEdgeToEdgeEnforcement">true</item>
    </style>
</resources>
