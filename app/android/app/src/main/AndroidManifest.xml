<?xml version="1.0" encoding="utf-8" ?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">
        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- QR deep links: /j/<sessionId> (per-session) and /g/<code>
                 (permanent per-guide, boarding addendum) open the app.
                 autoVerify needs /.well-known/assetlinks.json on the site
                 with the release signing cert's SHA-256
                 (see app/store-setup/SETUP.md). -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="fieldnote.guide" android:pathPrefix="/j/" />
                <data android:scheme="https" android:host="fieldnote.guide" android:pathPrefix="/g/" />
            </intent-filter>

            <!-- Custom scheme (fieldnote://j/<id>, fieldnote://g/<code>):
                 the router page's "Open my tour in the app" button uses it
                 because iOS suppresses same-domain universal links; Android
                 registers it for parity. No autoVerify — custom schemes
                 aren't verified. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="fieldnote" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data android:name="android.support.FILE_PROVIDER_PATHS" android:resource="@xml/file_paths" />
        </provider>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Live tour map: passenger/guide position while the app is in use. -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <!-- Android 13+ runtime permission for push notifications. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
</manifest>
